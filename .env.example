# ────────────────────────────────────────────────────────────────────────────
# GetPostFlow — Environment Variables Reference
# Copy this file to .env.local for local development.
# All values are required unless marked [optional].
# Never commit .env.local or any file containing real secrets.
# ────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL. Set to staging or production URL in deployed environments.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string (includes pgvector extension).
# Get from: https://console.neon.tech → your project → Connection Details
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/getpostflow

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Used by BullMQ workers and the API layer for caching and queues.
# Get from: https://console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# ioredis-compatible connection string for BullMQ worker process:
REDIS_URL=

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Publishable key is safe to expose on the client side.
# Get from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhook secret for syncing user events to your DB:
CLERK_WEBHOOK_SECRET=
# Clerk route config (these are set automatically in next.config.ts but you can override here):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Secret key for server-side Stripe API calls.
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
# Webhook signing secret for validating Stripe webhook events:
STRIPE_WEBHOOK_SECRET=
# [optional] Publishable key if you need client-side Stripe Elements:
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Object storage for media assets, generated images, and video.
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=getpostflow-assets
# Public CDN URL for the R2 bucket (if public access is enabled):
R2_PUBLIC_URL=

# ── Ably Realtime ─────────────────────────────────────────────────────────────
# Realtime pub/sub for inbox updates, approval notifications, and live ops.
# Get from: https://ably.com → your app → API Keys
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_PUBLISHABLE_KEY=

# ── Resend Email ──────────────────────────────────────────────────────────────
# Transactional email for notifications, reports, and approval flows.
# Get from: https://resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@getpostflow.com

# ── Sentry Observability ─────────────────────────────────────────────────────
# Error tracking for apps/web and apps/worker.
# Get from: https://sentry.io → your project → Settings → SDK Setup
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# [optional] Auth token for source map uploads in CI:
SENTRY_AUTH_TOKEN=

# ── PostHog Product Analytics ─────────────────────────────────────────────────
# Product analytics, funnels, and feature flags.
# Get from: https://app.posthog.com → your project → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Axiom Logging ─────────────────────────────────────────────────────────────
# Structured log ingestion for web and worker.
# Get from: https://app.axiom.co → your team → Settings → API Tokens
AXIOM_TOKEN=
AXIOM_DATASET=getpostflow-logs

# ── BullMQ / Worker ───────────────────────────────────────────────────────────
# Queue configuration for apps/worker on Fly.io.
# REDIS_URL above is used by BullMQ. These are additional worker settings:
WORKER_CONCURRENCY=5
WORKER_MAX_JOBS_PER_WORKER=100

# ── AI Providers ──────────────────────────────────────────────────────────────
# Model keys are used server-side only (never expose to client).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=

# ── Social Platform OAuth ─────────────────────────────────────────────────────
# Client IDs are public; secrets are server-side only.
# Set redirect URIs in each platform's developer console to:
#   {NEXT_PUBLIC_APP_URL}/api/oauth/{platform}/callback

# Meta (Facebook + Instagram)
META_APP_ID=
META_APP_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google / YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Ayrshare (Social Media API aggregator) ─────────────────────────────────────
# Used as the default posting provider in v1 while direct platform API approvals
# are being processed. Obtain your key at https://app.ayrshare.com
# Get from: https://app.ayrshare.com → Dashboard → API Key
AYRSHARE_API_KEY=
AYRSHARE_BASE_URL=https://app.ayrshare.com/api

# ── Social provider routing ────────────────────────────────────────────────────
# SOCIAL_PROVIDER_DEFAULT controls which backend is used for all platforms.
# "ayrshare" (default in v1) routes through Ayrshare.
# "direct" uses the platform's native API (requires approved app credentials above).
SOCIAL_PROVIDER_DEFAULT=ayrshare

# Per-platform overrides — uncomment a line to switch that platform to direct API
# once its developer app has been approved and credentials are set above.
# SOCIAL_PROVIDER_FACEBOOK=direct
# SOCIAL_PROVIDER_INSTAGRAM=direct
# SOCIAL_PROVIDER_TIKTOK=direct
# SOCIAL_PROVIDER_YOUTUBE=direct
# SOCIAL_PROVIDER_YOUTUBE_SHORTS=direct
# SOCIAL_PROVIDER_LINKEDIN=direct
# SOCIAL_PROVIDER_PINTEREST=direct
# SOCIAL_PROVIDER_REDDIT=direct
# SOCIAL_PROVIDER_DISCORD=direct
